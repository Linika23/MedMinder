        "@nestjs/testing": "^10.4.0",
        "@types/bcrypt": "^5.0.2",
        "@types/cookie-parser": "^1.4.7",
        "@types/express": "^5.0.0",
        "@types/jest": "^29.5.14",
        "@types/node": "^22.10.0",
        "@types/passport-jwt": "^4.0.1",
        "@types/passport-local": "^1.0.38",
