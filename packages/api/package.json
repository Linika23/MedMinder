        "jest": "^29.7.0",
        "prisma": "^6.4.0",
        "rimraf": "^6.0.0",
        "supertest": "^7.0.0",
        "ts-jest": "^29.2.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.7.0"
