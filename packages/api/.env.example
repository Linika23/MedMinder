# ============================================================
# MedMinder API — Environment Variables (LOCAL DEV)
# Copy this file to .env.local and fill in your values
# ============================================================

# Database
DATABASE_URL="postgresql://medminder:medminder_dev@localhost:5432/medminder?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# CORS
CORS_ORIGINS="http://localhost:3000"

# Port
PORT=4000

# --- External APIs (fill in when ready) ---

# DrugBank API (Phase 2)
# DRUGBANK_API_KEY=""

# Google Cloud Vision (Phase 1 - OCR)
# GOOGLE_CLOUD_VISION_KEY=""

# Anthropic Claude API (Phase 2 - AI summaries)
# ANTHROPIC_API_KEY=""

# OpenAI fallback (Phase 2)
# OPENAI_API_KEY=""

# Twilio SMS (Phase 1 - reminders)
# TWILIO_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_PHONE=""

# SendGrid Email (Phase 1 - reminders)
# SENDGRID_API_KEY=""

# Firebase (Phase 1 - push notifications)
# FIREBASE_SERVICE_ACCOUNT=""

# S3/R2 file storage (Phase 1 - OCR images)
# S3_BUCKET=""
# S3_REGION=""
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""

# Sentry (Phase 5)
# SENTRY_DSN=""

# PostHog Analytics (Phase 5)
# POSTHOG_KEY=""
