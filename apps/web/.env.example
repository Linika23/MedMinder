# API URL (backend proxy target)
NEXT_PUBLIC_API_URL=http://localhost:4000

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-change-in-production

# OAuth Providers (Phase 0)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# APPLE_CLIENT_ID=""
# APPLE_CLIENT_SECRET=""
