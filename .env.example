# ============================================================
# MedMinder — Environment Variables Template
# Copy to .env.local and fill in your values
# ============================================================

# ── Database ──
DATABASE_URL="postgresql://user:password@localhost:5432/medminder?schema=public"

# ── Auth ──
JWT_SECRET="your-jwt-secret-min-32-chars"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="30d"

# ── App URLs ──
NEXT_PUBLIC_API_URL="http://localhost:4000"
APP_URL="http://localhost:3000"
CORS_ORIGINS="http://localhost:3000"

# ── External APIs ──
ANTHROPIC_API_KEY=""
OPENFDA_BASE_URL="https://api.fda.gov"

# ── Notifications ──
SENDGRID_API_KEY=""
FROM_EMAIL="noreply@medminder.app"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ── Monitoring ──
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# ── Production Only ──
# NODE_ENV="production"
# PORT="4000"
